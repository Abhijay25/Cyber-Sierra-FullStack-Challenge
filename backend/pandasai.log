# Calculate the average age and percentage of people in each age range
sql_query = """
WITH AgeStats AS (
    SELECT 
        AVG(Age) AS average_age,
        CASE
            WHEN Age < 18 THEN 'Under 18'
            WHEN Age BETWEEN 18 AND 35 THEN '18-35'
            WHEN Age BETWEEN 36 AND 55 THEN '36-55'
            ELSE '56 and above'
        END AS Age_Group,
        COUNT(*) AS count
    FROM table_aec7a6bd6f78cb97d53618ce510b61d8
    WHERE Age IS NOT NULL
    GROUP BY Age_Group
),
TotalCount AS (
    SELECT SUM(count) AS total_count FROM AgeStats
)
SELECT 
    AgeStats.Age_Group,
    AgeStats.count,
    (AgeStats.count / TotalCount.total_count) * 100 AS percentage
FROM 
    AgeStats, TotalCount
"""

# Execute the SQL query
age_stats_df = execute_sql_query(sql_query)

# Declare result var:
result = { "type": "dataframe", "value": age_stats_df }
