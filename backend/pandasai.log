# TODO: import the required dependencies
import pandas as pd

# Write code here
query = """
    WITH FamilySize AS (
        SELECT *,
               (SibSp + Parch + 1) AS family_size
        FROM table_aec7a6bd6f78cb97d53618ce510b61d8
    ),
    SurvivalRates AS (
        SELECT
            CASE
                WHEN family_size = 1 THEN 'Alone'
                WHEN family_size > 4 THEN 'Large Family'
                ELSE 'Other'
            END AS group_type,
            AVG(Survived) * 100 AS survival_rate
        FROM FamilySize
        GROUP BY 1
    )
    SELECT *
    FROM SurvivalRates
    WHERE group_type IN ('Alone', 'Large Family')
"""

# Execute the query
result_df = execute_sql_query(query)

# Declare result var
result = { "type": "dataframe", "value": result_df }
